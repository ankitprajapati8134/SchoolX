# ─────────────────────────────────────────────────────────────────
# Grader School ERP — Environment Configuration
# Copy this file to .env and fill in your production values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# Encryption key — generate with: php -r "echo bin2hex(random_bytes(32));"
ENCRYPTION_KEY=CHANGE_ME_GENERATE_A_64_CHAR_HEX_KEY

# Backup cron — comma-separated allowed IPs (empty = no IP restriction)
BACKUP_CRON_ALLOWED_IPS=127.0.0.1,::1

# HTTPS enforcement — set to "true" to force PHP-level HTTPS redirect
# (Also uncomment the .htaccess RewriteRule for Apache-level redirect)
FORCE_HTTPS=false

# Domain name — used for HSTS preload and CSP if needed
# APP_DOMAIN=school.example.com
